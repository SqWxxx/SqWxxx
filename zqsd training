<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ZQSD Rush</title>
  <style>
    :root {
      --bg-1: #08141d;
      --bg-2: #163042;
      --bg-3: #24566b;
      --panel: rgba(8, 17, 24, 0.78);
      --text: #f7f2dd;
      --muted: rgba(247, 242, 221, 0.72);
      --accent: #ffbf69;
      --accent-2: #7bd389;
      --danger: #ff6b6b;
      --key: rgba(255, 255, 255, 0.1);
      --key-active: #f4a261;
      --key-done: #7bd389;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      min-height: 100vh;
      display: grid;
      place-items: center;
      padding: 24px;
      font-family: "Trebuchet MS", Verdana, sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at top, rgba(255, 206, 107, 0.2), transparent 24%),
        radial-gradient(circle at 15% 80%, rgba(123, 211, 137, 0.18), transparent 20%),
        radial-gradient(circle at 85% 18%, rgba(110, 168, 255, 0.2), transparent 22%),
        linear-gradient(135deg, var(--bg-1) 0%, var(--bg-2) 54%, var(--bg-3) 100%);
      overflow: hidden;
    }

    body::before,
    body::after {
      content: "";
      position: fixed;
      inset: auto;
      pointer-events: none;
      filter: blur(10px);
      opacity: 0.5;
    }

    body::before {
      width: 420px;
      height: 420px;
      top: -120px;
      right: -60px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(255, 191, 105, 0.22), transparent 68%);
    }

    body::after {
      width: 380px;
      height: 380px;
      bottom: -140px;
      left: -80px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(123, 211, 137, 0.18), transparent 68%);
    }

    .shell {
      width: min(100%, 760px);
      padding: 28px;
      border-radius: 30px;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.02)),
        var(--panel);
      border: 1px solid rgba(255, 255, 255, 0.12);
      box-shadow:
        0 30px 80px rgba(0, 0, 0, 0.35),
        inset 0 1px 0 rgba(255, 255, 255, 0.08);
      backdrop-filter: blur(16px);
    }

    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: start;
      gap: 16px;
      margin-bottom: 22px;
      flex-wrap: wrap;
    }

    h1 {
      margin: 0 0 8px;
      font-size: clamp(2.2rem, 5vw, 4.2rem);
      line-height: 0.95;
      letter-spacing: 0.04em;
    }

    .subtitle {
      margin: 0;
      color: var(--muted);
      font-size: 1rem;
    }

    .status {
      padding: 12px 16px;
      border-radius: 999px;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.06));
      border: 1px solid rgba(255, 255, 255, 0.08);
      font-weight: 700;
      white-space: nowrap;
    }

    .stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
      margin-bottom: 24px;
    }

    .stat {
      padding: 16px;
      border-radius: 20px;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.09), rgba(255, 255, 255, 0.04));
      border: 1px solid rgba(255, 255, 255, 0.07);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
    }

    .stat span {
      display: block;
      font-size: 0.82rem;
      color: var(--muted);
      margin-bottom: 6px;
    }

    .stat strong {
      font-size: clamp(1.6rem, 3vw, 2.3rem);
    }

    .arena {
      padding: 24px;
      border-radius: 28px;
      background:
        radial-gradient(circle at top, rgba(255, 255, 255, 0.06), transparent 45%),
        linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.02)),
        rgba(0, 0, 0, 0.12);
      border: 1px solid rgba(255, 255, 255, 0.08);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
    }

    .sequence {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      margin-bottom: 18px;
    }

    .key {
      min-height: 112px;
      border-radius: 24px;
      display: grid;
      place-items: center;
      font-size: clamp(2.3rem, 6vw, 4rem);
      font-weight: 900;
      letter-spacing: 0.08em;
      color: #f9f5e8;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0.04) 32%),
        linear-gradient(180deg, #284556, #142834);
      border: 1px solid rgba(255, 255, 255, 0.12);
      transition: transform 120ms ease, background 120ms ease, box-shadow 120ms ease, border-color 120ms ease;
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.12),
        inset 0 -14px 24px rgba(0, 0, 0, 0.26),
        0 14px 30px rgba(0, 0, 0, 0.18);
      text-shadow: 0 2px 8px rgba(0, 0, 0, 0.35);
    }

    .key.active {
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.34), rgba(255, 255, 255, 0.08) 28%),
        linear-gradient(180deg, #ffbf69, #f28f3b);
      color: #30200f;
      transform: translateY(-4px) scale(1.02);
      border-color: rgba(255, 224, 163, 0.72);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.3),
        0 0 0 2px rgba(255, 191, 105, 0.18),
        0 18px 36px rgba(242, 143, 59, 0.34);
    }

    .key.done {
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.26), rgba(255, 255, 255, 0.08) 28%),
        linear-gradient(180deg, #9be29b, #59c36a);
      color: #16331b;
      border-color: rgba(176, 255, 187, 0.46);
    }

    .key.wrong {
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.2), rgba(255, 255, 255, 0.06) 28%),
        linear-gradient(180deg, #ff9f9f, #ff6b6b);
      color: #381212;
      border-color: rgba(255, 191, 191, 0.5);
    }

    .center {
      display: grid;
      gap: 16px;
      justify-items: center;
      text-align: center;
      margin: 20px 0 10px;
    }

    .prompt {
      font-size: clamp(1.1rem, 2vw, 1.4rem);
      color: var(--muted);
    }

    .feedback {
      min-height: 1.5em;
      font-weight: 700;
      color: var(--accent);
    }

    .actions {
      display: flex;
      justify-content: center;
      gap: 12px;
      flex-wrap: wrap;
      margin-top: 18px;
    }

    button {
      border: 0;
      border-radius: 999px;
      padding: 14px 22px;
      font: inherit;
      font-weight: 800;
      color: #16231a;
      cursor: pointer;
      background: linear-gradient(135deg, var(--accent), #ffd166);
      box-shadow: 0 14px 30px rgba(255, 191, 105, 0.22);
    }

    .secondary {
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.11), rgba(255, 255, 255, 0.05));
      color: var(--text);
      border: 1px solid rgba(255, 255, 255, 0.08);
      box-shadow: none;
    }

    .help {
      margin-top: 18px;
      text-align: center;
      color: var(--muted);
    }

    @media (max-width: 640px) {
      .shell {
        padding: 20px;
      }

      .stats {
        grid-template-columns: 1fr;
      }

      .sequence {
        gap: 10px;
      }

      .key {
        min-height: 84px;
        border-radius: 18px;
      }
    }
  </style>
</head>
<body>
  <main class="shell">
    <div class="topbar">
      <div>
        <h1>ZQSD RUSH</h1>
        <p class="subtitle">Appuie sur Z, puis Q, puis S, puis D le plus vite possible pendant 20 secondes.</p>
      </div>
      <div class="status" id="status">Pret</div>
    </div>

    <section class="stats">
      <div class="stat">
        <span>Score</span>
        <strong id="score">0</strong>
      </div>
      <div class="stat">
        <span>Temps restant</span>
        <strong id="timer">20</strong>
      </div>
      <div class="stat">
        <span>Meilleur score</span>
        <strong id="best">0</strong>
      </div>
    </section>

    <section class="arena">
      <div class="sequence" id="sequence">
        <div class="key active" data-key="z">Z</div>
        <div class="key" data-key="q">Q</div>
        <div class="key" data-key="s">S</div>
        <div class="key" data-key="d">D</div>
      </div>

      <div class="center">
        <div class="prompt">Tape la sequence dans le bon ordre pour marquer 1 point.</div>
        <div class="feedback" id="feedback">Appuie sur Commencer puis enchaine.</div>
      </div>

      <div class="actions">
        <button id="start" type="button">Commencer</button>
        <button id="restart" type="button" class="secondary">Reinitialiser</button>
      </div>
    </section>

    <div class="help">Touches reconnues: Z, Q, S, D. Appuie sur R pour remettre le meilleur score a zero.</div>
  </main>

  <script>
    const ORDER = ["z", "q", "s", "d"];
    const GAME_DURATION = 20;
    const BEST_KEY = "zqsd-rush-best-score";

    const scoreEl = document.getElementById("score");
    const timerEl = document.getElementById("timer");
    const bestEl = document.getElementById("best");
    const statusEl = document.getElementById("status");
    const feedbackEl = document.getElementById("feedback");
    const startBtn = document.getElementById("start");
    const restartBtn = document.getElementById("restart");
    const keyEls = [...document.querySelectorAll(".key")];

    let score = 0;
    let bestScore = Number(localStorage.getItem(BEST_KEY) || 0);
    let currentIndex = 0;
    let timeLeft = GAME_DURATION;
    let isRunning = false;
    let endTime = 0;
    let timerId = null;
    let wrongFlashTimeout = null;

    bestEl.textContent = bestScore;

    function updateKeys(wrongKey = null) {
      keyEls.forEach((keyEl, index) => {
        const expected = ORDER[index];
        keyEl.classList.remove("active", "done", "wrong");

        if (wrongKey && wrongKey === expected) {
          keyEl.classList.add("wrong");
          return;
        }

        if (index < currentIndex) {
          keyEl.classList.add("done");
        } else if (index === currentIndex) {
          keyEl.classList.add("active");
        }
      });
    }

    function syncHud() {
      scoreEl.textContent = score;
      timerEl.textContent = timeLeft;
      bestEl.textContent = bestScore;
      statusEl.textContent = isRunning ? "En cours" : timeLeft === 0 ? "Termine" : "Pret";
    }

    function clearWrongFlash() {
      if (wrongFlashTimeout) {
        clearTimeout(wrongFlashTimeout);
        wrongFlashTimeout = null;
      }
    }

    function resetSequence(message = "Sequence reinitialisee.") {
      currentIndex = 0;
      feedbackEl.textContent = message;
      updateKeys();
    }

    function finishGame() {
      isRunning = false;
      clearInterval(timerId);
      timerId = null;
      clearWrongFlash();
      currentIndex = 0;
      updateKeys();
      syncHud();
      feedbackEl.textContent = "Temps ecoule. Score final: " + score + ".";
      startBtn.textContent = "Rejouer 20s";
    }

    function tick() {
      const remainingMs = Math.max(0, endTime - Date.now());
      timeLeft = Math.ceil(remainingMs / 1000);
      syncHud();

      if (remainingMs <= 0) {
        timeLeft = 0;
        finishGame();
      }
    }

    function startGame() {
      score = 0;
      currentIndex = 0;
      timeLeft = GAME_DURATION;
      isRunning = true;
      endTime = Date.now() + GAME_DURATION * 1000;
      clearInterval(timerId);
      timerId = setInterval(tick, 100);
      startBtn.textContent = "Partie en cours";
      feedbackEl.textContent = "C'est parti. Commence par Z.";
      updateKeys();
      syncHud();
    }

    function resetGame() {
      isRunning = false;
      score = 0;
      timeLeft = GAME_DURATION;
      currentIndex = 0;
      clearInterval(timerId);
      timerId = null;
      clearWrongFlash();
      startBtn.textContent = "Commencer";
      feedbackEl.textContent = "Appuie sur Commencer puis enchaine.";
      updateKeys();
      syncHud();
    }

    function resetBestScore() {
      bestScore = 0;
      localStorage.setItem(BEST_KEY, "0");
      syncHud();
      feedbackEl.textContent = "Meilleur score reinitialise.";
    }

    function handleCorrectKey() {
      currentIndex += 1;

      if (currentIndex === ORDER.length) {
        score += 1;
        if (score > bestScore) {
          bestScore = score;
          localStorage.setItem(BEST_KEY, String(bestScore));
        }
        currentIndex = 0;
        feedbackEl.textContent = "Bien joue. Continue.";
      } else {
        feedbackEl.textContent = "Parfait. Prochaine touche: " + ORDER[currentIndex].toUpperCase();
      }

      updateKeys();
      syncHud();
    }

    function handleWrongKey(key) {
      clearWrongFlash();
      currentIndex = 0;
      feedbackEl.textContent = "Mauvais ordre. Reprends a Z.";
      updateKeys(key);
      wrongFlashTimeout = setTimeout(() => {
        updateKeys();
      }, 180);
    }

    window.addEventListener("keydown", (event) => {
      const key = event.key.toLowerCase();

      if (key === "r") {
        event.preventDefault();
        resetBestScore();
        return;
      }

      if (!ORDER.includes(key)) {
        return;
      }

      event.preventDefault();

      if (!isRunning) {
        return;
      }

      if (key === ORDER[currentIndex]) {
        handleCorrectKey();
      } else {
        handleWrongKey(key);
      }
    });

    startBtn.addEventListener("click", () => {
      if (!isRunning) {
        startGame();
      }
    });

    restartBtn.addEventListener("click", resetGame);

    resetGame();
  </script>
</body>
</html>
